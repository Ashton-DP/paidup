# ── Xero ──────────────────────────────────────────────────────────────────────
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=http://localhost:3000/xero/callback
XERO_WEBHOOK_KEY=your_xero_webhook_key

# ── Gemini (AI message generation — free tier, the default) ──────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic (Claude) — optional, no longer used ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Email sending ─────────────────────────────────────────────────────────────
# PRODUCTION: Resend (https://resend.com). Verify your domain there (adds SPF +
# DKIM DNS records) and send from an address on it. If RESEND_API_KEY is set it
# is used; otherwise the app falls back to Gmail SMTP (below) for local/dev.
RESEND_API_KEY=re_xxx
FROM_EMAIL=reminders@yourdomain.com
FROM_NAME=Your Business Name

# Fallback: Gmail SMTP (App Password) — dev only, before the domain is verified.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Paystack (ZAR subscriptions) ──────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxx
# Create 3 recurring Plans in the Paystack dashboard (R299/R599/R999) and paste
# their plan codes here. If left blank, checkout falls back to a one-off charge.
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_GROWTH=
PAYSTACK_PLAN_BUSINESS=

# ── App ───────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string
PORT=3000
BASE_URL=http://localhost:3000
