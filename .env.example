# ── Xero ──────────────────────────────────────────────────────────────────────
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=http://localhost:3000/xero/callback
XERO_WEBHOOK_KEY=your_xero_webhook_key

# ── Gemini (AI message generation — free tier, the default) ──────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic (Claude) — optional, no longer used ────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── SendGrid (email) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=invoices@yourbusiness.co.za
FROM_NAME=Your Business Name

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_long_random_string
DASHBOARD_PASSWORD=set_a_password_to_protect_the_dashboard  # required in production
PORT=3000
BASE_URL=http://localhost:3000
